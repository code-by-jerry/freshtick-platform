APP_NAME=Freshtick
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com
APP_TIMEZONE=Asia/Kolkata
NEXT_DAY_DELIVERY_CUTOFF=22:30

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# PostgreSQL (default for Freshtick)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=scommerce
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Analytics & marketing (optional)
GTM_ID=
META_PIXEL_ID=
GOOGLE_ADS_ID=
META_DESCRIPTION="${APP_NAME} – Fresh dairy delivered daily."
META_ROBOTS="index, follow"

# SMS (MSG91 / Twilio)
SMS_DRIVER=log
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# MSG91_BASE_URL=https://control.msg91.com/api/v5
# MSG91_COUNTRY_CODE=91
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=

# WhatsApp API

# Payments
PAYMENT_GATEWAY=razorpay
PAYMENT_CURRENCY=INR
PAYMENT_MOCK=false

# Razorpay (use test keys for local/staging, replace with live keys for production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (optional fallback/alternative)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
